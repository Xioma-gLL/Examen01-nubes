# Opcion recomendada para Render: una sola URL de conexion Postgres
DATABASE_URL=postgresql://usuario:password@host:5432/database

# Opcional para ejecucion local con flask run/python app.py
FLASK_DEBUG=1
PORT=5000

# Alternativa si no usas DATABASE_URL
# DB_HOST=localhost
# DB_NAME=mi_base
# DB_USER=mi_usuario
# DB_PASSWORD=mi_password
# DB_PORT=5432
# DB_SSLMODE=disable
